{
  "name": "soundrush",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "electron-dev": "electron .",
    "electron-build": "electron-builder --linux"
  },
  "build": {
    "appId": "com.soundrush.app",
    "productName": "SoundRush",
    "directories": { "output": "release" },
    "files": [
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "linux": { "target": "AppImage", "icon": "public/icon.jpeg" }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {}
}
