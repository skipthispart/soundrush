{
  "manifest_version": 3,
  "name": "SoundRush — Music Downloader",
  "version": "1.0.0",
  "description": "Download music from YouTube, Spotify, SoundCloud, Deezer and more. Audio up to FLAC Lossless.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.youtu.be/*",
        "*://*.music.youtube.com/*",
        "*://*.soundcloud.com/*",
        "*://*.spotify.com/*",
        "*://*.deezer.com/*",
        "*://*.tidal.com/*",
        "*://*.music.apple.com/*",
        "*://*.bandcamp.com/*",
        "*://*.pandora.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.youtu.be/*",
    "*://*.music.youtube.com/*",
    "*://*.soundcloud.com/*",
    "*://*.spotify.com/*",
    "*://*.deezer.com/*",
    "*://*.tidal.com/*",
    "*://*.music.apple.com/*",
    "*://*.bandcamp.com/*",
    "*://*.pandora.com/*"
  ]
}
